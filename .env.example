# ──────────────────────────────────────────────
# Backend (apps/api) — usado a partir do M1
# ──────────────────────────────────────────────
API_PORT=3333
# Postgres provisionado pelo docker-compose.yml (host na 55432 p/ evitar conflitos comuns na 5432/5433)
DATABASE_URL=postgresql://ocr:ocr@localhost:55432/ocr

# ──────────────────────────────────────────────
# Mobile (apps/mobile) — usado a partir do M2
# Variáveis EXPO_PUBLIC_* são embutidas no bundle.
# ──────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3333
